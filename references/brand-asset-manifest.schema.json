{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Brand Asset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "brand", "assets"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "brand": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "dag": { "type": "string", "minLength": 1 },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/asset" }
    }
  },
  "$defs": {
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "mediaType": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "aspectRatio": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?:[0-9]+(?:\\.[0-9]+)?$" },
        "colorMode": { "type": "string", "minLength": 1 },
        "bytes": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "producer": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "dagNode": { "type": "string", "minLength": 1 },
        "promptVersion": { "type": "string", "minLength": 1 },
        "promptHash": { "type": "string", "minLength": 1 },
        "inputVersions": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "attempts": { "type": "integer", "minimum": 0 },
        "billedCalls": { "type": "integer", "minimum": 0 },
        "estimatedCost": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "minLength": 1 }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewed", "checks"],
      "properties": {
        "reviewed": { "type": "boolean" },
        "reviewer": { "type": "string", "minLength": 1 },
        "checks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "notes": { "type": "string" }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "role", "assetClass", "status", "dependencies"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "planItem": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "role": {
          "enum": ["deliverable", "derivative", "dependency", "exploration", "evidence"]
        },
        "assetClass": { "type": "string", "minLength": 1 },
        "status": {
          "enum": ["planned", "generated", "accepted", "complete", "rejected", "blocked", "invalidated", "not-applicable", "external-handoff"]
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "output": { "$ref": "#/$defs/output" },
        "generation": { "$ref": "#/$defs/generation" },
        "derivation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method"],
          "properties": {
            "method": { "type": "string", "minLength": 1 },
            "sourceAsset": { "type": "string", "minLength": 1 },
            "tool": { "type": "string", "minLength": 1 },
            "command": { "type": "string", "minLength": 1 }
          }
        },
        "validation": { "$ref": "#/$defs/validation" },
        "usage": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blocker": { "type": "string", "minLength": 1 },
        "statusReason": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "enum": ["generated", "accepted", "complete", "external-handoff"] } },
            "required": ["status"]
          },
          "then": { "required": ["output"] }
        },
        {
          "if": {
            "properties": { "status": { "enum": ["accepted", "complete", "external-handoff"] } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "output": { "required": ["bytes", "sha256"] }
            }
          }
        },
        {
          "if": {
            "properties": {
              "role": { "enum": ["deliverable", "derivative"] },
              "status": { "enum": ["accepted", "complete", "external-handoff"] }
            },
            "required": ["role", "status"]
          },
          "then": {
            "required": ["validation"],
            "properties": {
              "validation": {
                "properties": { "reviewed": { "const": true } },
                "required": ["reviewed"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "blocked" } },
            "required": ["status"]
          },
          "then": { "required": ["blocker"] }
        }
      ]
    }
  }
}
